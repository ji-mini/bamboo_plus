generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Post {
  id                 String       @id @default(uuid()) @db.Uuid
  title              String
  content            String
  category           PostCategory
  status             PostStatus   @default(PENDING)
  authorPasswordHash String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  approvedAt         DateTime?
  rejectedReason     String?

  @@index([status, category, createdAt])
}

model AdminUser {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String
  role         String   @default("ADMIN")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum PostCategory {
  SUGGESTION
  PRAISE
  COMPLAINT
  ETC
}

enum PostStatus {
  PENDING
  APPROVED
  REJECTED
}
